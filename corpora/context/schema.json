{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContextCorpusEntry",
  "type": "object",
  "required": ["id", "expected_class", "finding_turn_idx", "turns"],
  "properties": {
    "id": {"type": "string", "description": "Unique entry identifier"},
    "expected_class": {
      "type": "string",
      "enum": ["real_paste", "educational", "documentation_quote", "model_hallucination", "unclassified"]
    },
    "finding_turn_idx": {"type": "integer", "minimum": 0},
    "detector_id": {"type": "string"},
    "matched_raw": {"type": "string"},
    "entropy_score": {"type": "number"},
    "span_kind": {"type": "string", "enum": ["single", "cross_turn"]},
    "turns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": {"type": "string", "enum": ["user", "assistant", "system", "tool"]},
          "content": {"type": "string"}
        }
      }
    }
  }
}
